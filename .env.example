NEXUSWF_USERNAME=your_username_or_email
NEXUSWF_PASSWORD=your_password
NEXUSWF_BASE_URL=https://app.nexuswf.com
ILSL_PORTAL_URL=https://portal.ilsl.co.uk/legal/files/records/index
# Optional — defaults to portal base + /entry
ILSL_ENTRY_URL=
# Optional — defaults to NEXUSWF credentials when unset
ILSL_USERNAME=
ILSL_PASSWORD=
# Minimum 5 hours; stretches per-row pacing, breaks, and idle time to match
ENTRY_DURATION_HOURS=5
# Default value for the File Executor field on the case entry form
FILE_EXECUTOR=Krzysztof Bednarczuk
HEADLESS=false
BROWSER_CHANNEL=
